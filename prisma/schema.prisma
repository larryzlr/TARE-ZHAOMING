// prisma/schema.prisma (PostgreSQL - 生产环境 Neon)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  category    String   @default("uncategorized")
  images      String?
  detailImages String?  // 详情页图片（JSON数组，最多3张，上下排列展示）
  status      String   @default("draft")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  translations ProductTranslation[]
  categoryTags ProductCategoryTag[]

  @@map("products")
}

// 产品多分类标签关联表（多对多）
// 一个产品可以绑定多个分类标签，例如同时属于"盘式刹车片"和"陶瓷刹车片"
model ProductCategoryTag {
  id          String   @id @default(cuid())
  productId   String
  categorySlug String
  createdAt   DateTime @default(now())

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, categorySlug])
  @@index([categorySlug])
  @@map("product_category_tags")
}

model ProductTranslation {
  id         String   @id @default(cuid())
  productId  String
  lang       String
  title      String
  description String?
  specs      String?
  detailContent String?  // 详情页富文本内容（HTML格式，支持图片、格式化文本）

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, lang])
  @@map("product_translations")
}

model SiteConfig {
  id    String @id @default(cuid())
  key   String
  value String
  lang  String

  @@unique([key, lang])
  @@map("site_configs")
}

model User {
  id       String    @id @default(cuid())
  email    String    @unique
  name     String?
  password String
  role     String    @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Translation {
  id        String   @id @default(cuid())
  lang      String   @unique
  content   String

  @@map("translations")
}

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  icon        String   @default("")
  parentId    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  translations CategoryTranslation[]

  @@map("categories")
}

model CategoryTranslation {
  id          String   @id @default(cuid())
  categoryId  String
  lang        String
  name        String

  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, lang])
  @@map("category_translations")
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  whatsapp  String?
  product   String?
  message   String?
  lang      String   @default("en")
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("inquiries")
}

model OeNumber {
  id          String   @id @default(cuid())
  oeNumber    String   @unique
  brand       String   @default("")
  model       String   @default("")
  resultType  String   @default("supported")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("oe_numbers")
}
